# ──────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# ──────────────────────────────────────────────────────────────
# Virtual Environments
# ──────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ──────────────────────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────
# Dataset (large files — download separately)
# ──────────────────────────────────────────────────────────────
dataset/Train/
dataset/Test/
dataset/Meta/
dataset/*.csv
dataset/*.zip
!dataset/README.md

# ──────────────────────────────────────────────────────────────
# Trained Models (large binary files)
# ──────────────────────────────────────────────────────────────
models/*.keras
models/*.h5
models/*.pkl
!models/.gitkeep

# ──────────────────────────────────────────────────────────────
# Outputs (generated at runtime)
# ──────────────────────────────────────────────────────────────
outputs/*.png
outputs/*.txt
!outputs/.gitkeep

# ──────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────
*.log
web/uploads/
.ipynb_checkpoints/
